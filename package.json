    "idb-keyval": "^6.2.1",
    "immer": "^9.0.15",
    "iso-639-1": "^2.1.15",
    "markdown-to-jsx": "^7.7.3",
    "next": "13.5.8",
    "node-fetch": "^3.3.2",
    "node-forge": "1.3.1",
    "posthog-js": "^1.236.8",
    "react": "*",
    "react-confetti": "6.1.0",
    "react-dom": "*",
    "react-hook-form": "7.51.0",
    "react-i18next": "^11.18.5",
    "react-transition-state": "^1.1.5",
    "react-use": "^17.4.0",
    "react-use-error-boundary": "^3.0.0",
    "react-use-intercom": "^5.1.4",
    "styled-components": "^5.3.5",
    "thirdweb": "^5.108.1",
    "tinyglobby": "^0.2.6",
    "ts-pattern": "^4.3.0",
    "use-immer": "^0.7.0",
    "viem": "2.19.4",
    "wagmi": "2.12.4"
  },
  "peerDependencies": {
    "react": "*",
